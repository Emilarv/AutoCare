<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imgDashboardLogo"
            android:layout_width="142dp"
            android:layout_height="70dp"
            android:layout_gravity="start"
            android:layout_marginBottom="20dp"
            android:adjustViewBounds="true"
            android:contentDescription="Logo AutoCare Dashboard"
            android:src="@drawable/logo_dashboard" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bienvenido de vuelta"
            android:textColor="#212121"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestiona tus vehículos y mantenimientos"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="24dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resumen General"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#E53935"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/txtDashVehiculosRegistrados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehículos registrados: 0"
                    android:textColor="#424242"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/txtDashMantenimientosPendientes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mantenimientos pendientes: 0"
                    android:textColor="#424242"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/txtDashGastosMes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gastos este mes: RD$ 0"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acciones rápidas"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVehiculos"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_columnSpan="2"
                android:layout_marginBottom="8dp"
                android:text="Mis Vehículos"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="#E53935"
                app:cornerRadius="12dp"
                app:elevation="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMantenimientos"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:text="Mantenimientos"
                android:textSize="13sp"
                android:textColor="#E53935"
                app:strokeColor="#E53935"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGastos"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="54dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="4dp"
                android:text="Gastos"
                android:textSize="13sp"
                android:textColor="#E53935"
                app:strokeColor="#E53935"
                app:strokeWidth="1.5dp"
                app:cornerRadius="12dp" />
        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFF5F5"
            app:strokeWidth="1dp"
            app:strokeColor="#FFCDD2"
            android:layout_marginTop="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recordatorios de Atención"
                    android:textColor="#C62828"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#C62828"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• "
                        android:textColor="#C62828"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toyota Corolla necesita cambio de aceite"
                        android:textColor="#D32F2F"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• "
                        android:textColor="#C62828"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Honda Civic tiene mantenimiento pendiente"
                        android:textColor="#D32F2F"
                        android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>