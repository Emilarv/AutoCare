<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalle del Vehículo"
            android:textColor="#757575"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/txtVehiculo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toyota Corolla"
            android:textColor="#212121"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:backgroundTint="#FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información General"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#E53935"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Número de Placa"
                        android:textColor="#757575"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="A123456"
                        android:textColor="#212121"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kilometraje Actual"
                        android:textColor="#757575"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="85,000 km"
                        android:textColor="#212121"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado del Vehículo"
                        android:textColor="#757575"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Activo"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F9FAFB"
            app:strokeWidth="1dp"
            app:strokeColor="#E4E7EB"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Historial Reciente"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:background="#BDBDBD"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Corregido el paddingVertical aquí -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No se encontraron mantenimientos registrados para este vehículo."
                    android:textColor="#757575"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregarMantenimiento"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Agregar Mantenimiento"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#E53935"
            app:cornerRadius="12dp"
            app:elevation="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMantenimiento"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ver Historial Completo"
            android:textSize="15sp"
            android:textColor="#E53935"
            app:strokeColor="#E53935"
            app:strokeWidth="1.5dp"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>